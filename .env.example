# ─── Supabase Configuration ─────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings

# Database (Project Settings → Database → Connection string URI → Transaction pooler)
DATABASE_URL=postgresql+asyncpg://postgres.[YOUR-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# JWT Secret (Project Settings → API → JWT Settings)
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Supabase API (Project Settings → API)
SUPABASE_URL=https://[YOUR-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ─── Redis Configuration ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Server ─────────────────────────────────────────────────────────
PORT=8000

# ─── CORS (comma-separated origins for production) ──────────────────
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
